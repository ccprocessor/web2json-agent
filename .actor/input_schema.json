{
  "title": "Web2JSON Agent Input",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "inputMode": {
      "title": "Input Mode",
      "type": "string",
      "description": "Input mode",
      "default": "url",
      "enum": ["url"],
      "editor": "select"
    },
    "urls": {
      "title": "URLs",
      "type": "array",
      "description": "List of URLs to parse",
      "editor": "json"
    },
    "domain": {
      "title": "Domain",
      "type": "string",
      "description": "Domain name",
      "editor": "textfield",
      "default": "parsed_data"
    },
    "iterationRounds": {
      "title": "Iteration Rounds",
      "type": "integer",
      "description": "Number of iteration rounds",
      "editor": "number",
      "default": 3,
      "minimum": 1,
      "maximum": 10
    }
  },
  "required": ["urls"]
}
