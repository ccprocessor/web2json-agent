{
  "title": "Web2JSON Agent Input",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "inputMode": {
      "title": "Input Mode",
      "type": "string",
      "description": "Input mode",
      "default": "url",
      "enum": ["url"],
      "editor": "select"
    },
    "urls": {
      "title": "URLs",
      "type": "array",
      "description": "List of URLs to parse",
      "editor": "json",
      "prefill": [
        "https://quotes.toscrape.com/page/1/",
        "https://quotes.toscrape.com/page/2/"
      ]
    },
    "domain": {
      "title": "Domain",
      "type": "string",
      "description": "Domain name",
      "editor": "textfield",
      "default": "parsed_data"
    },
    "iterationRounds": {
      "title": "Iteration Rounds",
      "type": "integer",
      "description": "Number of iteration rounds",
      "editor": "number",
      "default": 1,
      "minimum": 1,
      "maximum": 10
    },
    "schemaMode": {
      "title": "Schema Mode",
      "type": "string",
      "description": "Schema extraction mode: auto = automatically extract fields, predefined = use custom schema template",
      "default": "auto",
      "enum": ["auto", "predefined"],
      "editor": "select"
    },
    "predefinedSchema": {
      "title": "Predefined Schema",
      "type": "object",
      "description": "Custom schema template (only used when Schema Mode is 'predefined')",
      "editor": "json",
      "prefill": {
        "title": "string",
        "content": "string"
      }
    }
  },
  "required": ["urls"]
}
