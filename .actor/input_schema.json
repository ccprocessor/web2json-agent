{
  "title": "Web2JSON Agent - Simple Configuration",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "urls": {
      "title": "URLs to Parse",
      "type": "string",
      "description": "Enter URLs to parse (one per line)",
      "editor": "textarea",
      "example": "https://quotes.toscrape.com/page/1/\nhttps://quotes.toscrape.com/page/2/\nhttps://quotes.toscrape.com/page/3/",
      "prefill": "https://quotes.toscrape.com/page/1/\nhttps://quotes.toscrape.com/page/2/"
    },
    "domain": {
      "title": "Output Name (Optional)",
      "type": "string",
      "description": "Name for the output folder",
      "editor": "textfield",
      "default": "parsed_data"
    },
    "inputMode": {
      "type": "string",
      "default": "url",
      "editor": "hidden"
    },
    "iterationRounds": {
      "type": "integer",
      "default": 3,
      "editor": "hidden"
    },
    "clusterMode": {
      "type": "boolean",
      "default": false,
      "editor": "hidden"
    },
    "schemaMode": {
      "type": "string",
      "default": "auto",
      "editor": "hidden"
    }
  },
  "required": []
}
