{
  "title": "Web2JSON Agent - URL Parser",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "urls": {
      "title": "URLs to Parse",
      "type": "array",
      "description": "Add URLs to parse (click + to add more)",
      "items": {
        "type": "string",
        "editor": "textfield"
      },
      "minItems": 1,
      "prefill": [
        "https://quotes.toscrape.com/page/1/",
        "https://quotes.toscrape.com/page/2/"
      ]
    },
    "domain": {
      "title": "Output Name (Optional)",
      "type": "string",
      "description": "Name for the output folder",
      "editor": "textfield",
      "default": "parsed_data"
    },
    "inputMode": {
      "title": "Input Mode",
      "type": "string",
      "description": "Input mode",
      "default": "url",
      "editor": "hidden"
    },
    "iterationRounds": {
      "title": "Iteration Rounds",
      "type": "integer",
      "description": "Number of samples for learning",
      "default": 3,
      "editor": "hidden"
    },
    "clusterMode": {
      "title": "Cluster Mode",
      "type": "boolean",
      "description": "Enable layout clustering",
      "default": false,
      "editor": "hidden"
    },
    "schemaMode": {
      "title": "Schema Mode",
      "type": "string",
      "description": "Schema generation mode",
      "default": "auto",
      "editor": "hidden"
    }
  },
  "required": ["urls"]
}
